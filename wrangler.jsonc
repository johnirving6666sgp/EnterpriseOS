{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "enterprise-os",
  "main": "./worker/index.mjs",
  "compatibility_date": "2026-06-05",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "timeconnector.net",
      "custom_domain": true
    },
    {
      "pattern": "www.timeconnector.net",
      "custom_domain": true
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "enterprise-os-db",
      "database_id": "fb0493b2-7698-4693-881b-9d65b5acd341",
      "migrations_dir": "./migrations"
    }
  ],
  "triggers": {
    "crons": ["*/30 * * * *"]
  },
  "vars": {
    "ENVIRONMENT": "production",
    "OPENROUTER_SITE_URL": "https://timeconnector.net",
    "OPENROUTER_APP_NAME": "EnterpriseOS",
    "OPENAI_TRANSCRIPTION_MODEL": "whisper-1",
    "WORKFLOW_OWNER_ID": "larry"
  },
  "observability": {
    "enabled": true
  }
}
